DJANGO_SECRET_KEY=CHANGE..._KEY
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# DB_ENGINE options: django.db.backends.sqlite3 (default) | django.db.backends.postgresql | django.contrib.gis.db.backends.postgis
# For PostgreSQL: pip install psycopg2-binary (or psycopg for v3)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=guardtour
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Redis / Cache
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ACCESS_LIFETIME_DAYS=1
JWT_REFRESH_LIFETIME_DAYS=7
